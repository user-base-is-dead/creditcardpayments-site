# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:5173

# Auth
# IMPORTANT: change this to a long random string in production.
JWT_SECRET=dev-only-change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10


# Admin panel credentials — set a strong ADMIN_PASSWORD in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
